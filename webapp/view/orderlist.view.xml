<mvc:View
    controllerName="styker.com.trackordershipment.controller.orderlist"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core" xmlns:smartTable="sap.ui.comp.smarttable"
xmlns:smartFilterBar="sap.ui.comp.smartfilterbar"

    xmlns:table="sap.ui.table">

    <Page class="sapUiContentPadding">

        <content>

            <!-- Header -->
            <VBox class="sapUiSmallMarginBottom">

                <HBox
                    justifyContent="SpaceAround"
                    alignItems="Center"
                    class="kpiContainer"
                    width="100%">

                    <VBox alignItems="Center">
                        <Title text="12" class="kpiValue" />
                        <Text text="TOTAL ORDERS" class="kpiLabel" />
                    </VBox>

                    <VBox class="kpiDivider" />

                    <VBox alignItems="Center">
                        <Title text="002" class="kpiValue" />
                        <Text text="Division" class="kpiLabel" />
                    </VBox>

                    <VBox class="kpiDivider" />

                    <VBox alignItems="Center">
                        <Title text="160" class="kpiValue" />
                        <Text text="Total Number of Units" class="kpiLabel" />
                    </VBox>

                </HBox>

                <Title
                    text="Orders Shipment Status"
                    level="H2"
                    class="sapUiTinyMarginTop sapUiTinyMarginBottom" />

                <Text text="Showing Orders" />

            </VBox>

            <!-- Filters -->
               <smartFilterBar:SmartFilterBar
        id="smartFilterBar"
        entitySet="ZFTS_FEDEX_UNI_CORE_FIORI"
        persistencyKey="ShipmentSmartFilter" />

           <!-- Table -->
<smartTable:SmartTable
    id="smartTable" smartFilterId="smartFilterBar"
    entitySet="ZFTS_FEDEX_UNI_CORE_FIORI" 
    initiallyVisibleFields="tracking_num,div_name,customer_po,pkt_ctrl_num,stryker_order,UNIFIED_STATUS_DESC"
    tableType="Table" beforeRebindTable="onBeforeRebindTable"
    enableAutoBinding="true">

    <table:Table selectionMode="None" rowSelectionChange="onRowSelect"
        id="innerTable" 
        visibleRowCount="10">

        

      

    </table:Table>

</smartTable:SmartTable>
        </content>

    </Page>

</mvc:View>